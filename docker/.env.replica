# Preset: PostgreSQL streaming read replica
#
# DEV TEMPLATE ONLY — not for production. The postgres:postgres credentials
# below match the throwaway local compose Postgres. In any shared/prod
# environment replace them with real credentials from a secret manager
# (export DATABASE_REPLICA_URLS in your shell / a gitignored env file) and
# never commit the password.
DATABASE_REPLICA_URLS=postgresql://postgres:postgres@postgres_replica:5432/appdb
