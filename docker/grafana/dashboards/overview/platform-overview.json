{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["cpp-template", "overview"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timezone": "",
  "title": "Platform overview",
  "uid": "platform-overview",
  "version": 1,
  "panels": [
    {
      "type": "table",
      "id": 1,
      "title": "Scrape targets UP",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {"showHeader": false},
      "fieldConfig": {
        "defaults": {
          "custom": {"displayMode": "color-background", "align": "center"},
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null}, {"color": "green", "value": 1}
          ]}
        }
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true}}}
      ],
      "targets": [{"refId": "A", "expr": "up", "format": "table", "instant": true}]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "API req/s (1m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "targets": [{"refId": "A", "expr": "sum(rate(http_requests_total{job=\"cpp_api\"}[1m]))"}]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "5xx rate (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {
        "unit": "percentunit",
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "yellow", "value": 0.005}, {"color": "red", "value": 0.01}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(rate(http_requests_total{job=\"cpp_api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"cpp_api\"}[5m])), 1)"}]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "p99 latency (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {
        "unit": "s",
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cpp_api\"}[5m])))"}]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "DLQ depth",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(jobs_dlq_depth{type!=\"_total\"})"}]
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Workers alive",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null}, {"color": "green", "value": 1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(up{job=\"cpp_worker\"})"}]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "HTTP req/s by status class",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "sum by (status) (rate(http_requests_total{job=\"cpp_api\"}[1m]))", "legendFormat": "{{status}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "HTTP latency p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cpp_api\"}[5m])))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cpp_api\"}[5m])))", "legendFormat": "p95"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cpp_api\"}[5m])))", "legendFormat": "p99"}
      ]
    }
  ]
}
