  {
   "type": "timeseries",
   "id": 1,
   "title": "Requests per second by method+path",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 0
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps",
     "color": {
      "mode": "palette-classic"
     }
    }
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (method, path) (rate(http_requests_total{job=\"tarassov_me\", path=~\"$path\"}[1m]))",
     "legendFormat": "{{method}} {{path}}"
    }
   ]
  },
  {
   "type": "timeseries",
   "id": 2,
