{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["tarassov-me", "redis"],
  "time": {"from": "now-30m", "to": "now"},
  "title": "Redis",
  "uid": "redis",
  "version": 1,
  "templating": {"list": []},
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Redis up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null}, {"color": "green", "value": 1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "redis_up"}]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Connected clients",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"refId": "A", "expr": "redis_connected_clients"}]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Used memory",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {"unit": "decbytes"}},
      "targets": [{"refId": "A", "expr": "redis_memory_used_bytes"}]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Keys (db0)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"refId": "A", "expr": "redis_db_keys{db=\"db0\"}"}]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Evicted keys/sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {"defaults": {
        "unit": "ops",
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "red", "value": 0.1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "rate(redis_evicted_keys_total[1m])"}]
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Ops/sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [{"refId": "A", "expr": "rate(redis_commands_processed_total[1m])"}]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Commands by kind (top 10)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "topk(10, sum by (cmd) (rate(redis_commands_total[1m])))", "legendFormat": "{{cmd}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Hit / miss ratio",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "targets": [
        {"refId": "A", "expr": "rate(redis_keyspace_hits_total[5m]) / clamp_min(rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]), 1)", "legendFormat": "hit ratio"}
      ]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "Memory usage (used / rss / peak)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "decbytes", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "redis_memory_used_bytes", "legendFormat": "used"},
        {"refId": "B", "expr": "redis_memory_used_rss_bytes", "legendFormat": "rss"},
        {"refId": "C", "expr": "redis_memory_used_peak_bytes", "legendFormat": "peak"}
      ]
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Network throughput",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "rate(redis_net_input_bytes_total[1m])", "legendFormat": "in"},
        {"refId": "B", "expr": "rate(redis_net_output_bytes_total[1m])", "legendFormat": "out"}
      ]
    }
  ]
}
