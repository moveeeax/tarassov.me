    },
    {
     "refId": "E",
     "expr": "rate(pg_stat_database_tup_deleted{datname=\"appdb\"}[1m])",
     "legendFormat": "deleted"
    }
   ]
  },
  {
   "type": "timeseries",
   "id": 11,
   "title": "Cache hit ratio",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 4
