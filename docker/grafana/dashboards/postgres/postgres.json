    }
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(pg_stat_database_blks_hit{datname=\"appdb\"}[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit{datname=\"appdb\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=\"appdb\"}[5m])), 1)",
     "legendFormat": "hit ratio"
    }
   ]
  },
  {
