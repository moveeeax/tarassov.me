{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["cpp-template", "cpp-worker"],
  "time": {"from": "now-30m", "to": "now"},
  "title": "cpp-worker",
  "uid": "cpp-worker",
  "version": 1,
  "templating": {"list": []},
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Worker up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null}, {"color": "green", "value": 1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(up{job=\"cpp_worker\"})"}]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "DLQ depth",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(jobs_dlq_depth{type!=\"_total\"})"}]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Retry rate (1m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [{"refId": "A", "expr": "sum(rate(retries_total[1m]))"}]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Active jobs",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"refId": "A", "expr": "sum(worker_active_jobs)"}]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Jobs/sec",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [{"refId": "A", "expr": "sum(rate(jobs_processed_total[1m]))"}]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "DLQ depth by type",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "targets": [{"refId": "A", "expr": "jobs_dlq_depth{type!=\"_total\"}", "legendFormat": "{{type}}"}]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Jobs processed per second (by type × outcome)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "sum by (type, outcome) (rate(jobs_processed_total[1m]))", "legendFormat": "{{type}} / {{outcome}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "Processing latency (p50/p95/p99 by type)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, sum by (le, type) (rate(job_processing_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{type}}"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le, type) (rate(job_processing_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{type}}"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le, type) (rate(job_processing_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{type}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Active jobs now (by type)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "sum by (type) (worker_active_jobs)", "legendFormat": "active: {{type}}"}
      ]
    }
  ]
}
