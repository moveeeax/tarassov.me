{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["tarassov-me", "kafka"],
  "time": {"from": "now-30m", "to": "now"},
  "title": "Kafka",
  "uid": "kafka",
  "version": 1,
  "templating": {"list": []},
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Brokers up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null}, {"color": "green", "value": 1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(kafka_brokers)"}]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Topics",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"refId": "A", "expr": "count(count by (topic) (kafka_topic_partitions))"}]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Under-replicated partitions",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "red", "value": 1}
        ]}
      }},
      "targets": [{"refId": "A", "expr": "sum(kafka_topic_partition_under_replicated_partition)"}]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Total consumer lag",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"refId": "A", "expr": "sum(kafka_consumergroup_lag)"}]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Messages in per topic (rate 1m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[1m]))", "legendFormat": "{{topic}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Consumer lag by group/topic",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}} / {{topic}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "Partition leader count per broker",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "count by (broker) (kafka_topic_partition_leader)", "legendFormat": "broker {{broker}}"}
      ]
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Partition replica count",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}},
      "targets": [
        {"refId": "A", "expr": "sum by (topic) (kafka_topic_partition_replicas)", "legendFormat": "{{topic}}"}
      ]
    }
  ]
}
