# Build directories
build/
cmake-build-*/
out/

# IDE files
.vscode/*
!.vscode/*.sample
.idea/
*.swp
*.swo
*~
.DS_Store

# Compiled files
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake

# Logs
logs/
!logs/.gitkeep
*.log

# Testing
Testing/
test-results.xml
coverage/
*.gcda
*.gcno
*.gcov

# Local dev artefacts
.dev-token
compile_commands.json

# Documentation
docs/html/
docs/latex/
docs/xml/

# vcpkg
vcpkg/
vcpkg_installed/

# Conan
conan.lock
conanbuildinfo.*
conaninfo.txt

# Environment
.env
*.env
!docker/.env
!docker/.env.*
!project.env

# direnv — checked-in sample is envrc.sample (no leading dot to avoid
# .env globbing in security tools). Real .envrc and .envrc.local stay local.
.envrc
.envrc.local

# Local reference projects cloned for inspiration / pattern lifting.
# Always-untracked; never source-of-truth.
_reference/

# Config (keep samples)
# Local developer overrides never leave the machine.
config/*.local.json
config/local/
.env.local
!config/config.sample.json

# Dependencies
third_party/
external/

# Package managers
node_modules/

# Temporary files
*.tmp
*.bak
*.cache

# C++ specific
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Core dumps — anchored to repo root so the bare `core` pattern doesn't also
# swallow the src/core/ source directory (an unanchored `core` matches any path
# component named core → new files under src/core/ were silently untracked).
/core
/core.*
**/core.[0-9]*

# Docker
.dockerignore

# Per-developer Compose overrides — checked-in sample is .sample-suffixed.
docker/docker-compose.override.yml
docker-compose.override.yml

# Secrets
*.pem
*.key
*.crt
secrets/

# Helm values with secrets (keep chart defaults under helm/tarassov-me/, tarassov-me-worker/).
# Per-cluster overrides go in untracked files matching the patterns below.
helm/values.yaml
helm/values-worker.yaml
helm/values.*.yaml
helm/*.local.yaml
helm/values.secret.yaml
# Per-environment / prod overlays carry real creds — never commit them.
# The *.example.yaml templates ARE tracked (secret-free); copy one to
# values-prod.yaml and fill it in. The negation keeps the example tracked even
# if the glob above is ever broadened.
helm/**/values-prod.yaml
!helm/**/values-prod.example.yaml
# Helm dependency build artifacts (regenerated via `helm dependency build`).
helm/*/charts/
# Auto-generated dev JWT secret for make up-everything
docker/.jwt-dev-secret

# Demo env generated secrets (never commit)
helm/tarassov-me-env/.demo-secrets.env

# Local file-storage backend (Storage::LocalStorage) — never commit uploads
data/uploads/

# Purchased frontend template archive — extracted to a scratch dir, not tracked
BookCard*.zip
