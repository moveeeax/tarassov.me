{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "threads": 4
  },
  "logging": {
    "name": "cpp_api",
    "file": "logs/app.log",
    "level": "warn"
  },
  "observability": {
    "metrics_address": "0.0.0.0:9090",
    "service_name": "cpp_api_bench"
  },
  "database": {
    "primary": "postgresql://postgres:postgres@postgres:5432/appdb",
    "replicas": [],
    "pool_size": 50
  },
  "cache": {
    "use_sentinel": false,
    "url": "tcp://redis:6379",
    "pool_size": 50
  },
  "messaging": { "enabled": false }
}
