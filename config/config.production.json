{
  "_comment": "Production profile: every security toggle ON, every dev convenience OFF. Validate with `make prod-check` before deploying. Secrets come ONLY from the environment — this file must never contain literal credentials.",
  "app": {
    "env": "production",
    "name": "${APP_NAME}",
    "base_url": "${APP_BASE_URL}"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "threads": "${SERVER_THREADS:-4}",
    "max_body_bytes": 10485760,
    "ssl": {
      "enabled": false
    }
  },
  "shutdown": {
    "pre_stop_delay_sec": 5
  },
  "logging": {
    "name": "${LOG_NAME:-tarassov_me}",
    "file": "logs/app.log",
    "level": "${LOG_LEVEL:-info}",
    "format": "json"
  },
  "observability": {
    "metrics_address": "0.0.0.0:9090",
    "service_name": "${SERVICE_NAME:-tarassov_me_service}",
    "otlp_endpoint": "${OTLP_ENDPOINT:-}"
  },
  "database": {
    "primary": "postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT:-5432}/${DATABASE_NAME}",
    "replicas": [],
    "pool_size": "${DB_POOL_SIZE:-10}",
    "acquire_timeout_ms": 5000,
    "statement_timeout_ms": 30000,
    "migrations_enabled": false,
    "migrations_dir": "migrations"
  },
  "cache": {
    "use_sentinel": "${REDIS_USE_SENTINEL:-false}",
    "url": "tcp://${REDIS_HOST}:${REDIS_PORT:-6379}",
    "password": "${REDIS_PASSWORD}",
    "pool_size": "${CACHE_POOL_SIZE:-10}",
    "sentinel": {
      "password": "${REDIS_SENTINEL_PASSWORD:-}",
      "master_name": "${REDIS_MASTER_NAME:-mymaster}",
      "nodes": []
    }
  },
  "mail": {
    "enabled": "${MAIL_ENABLED:-true}",
    "via_jobs": "${MAIL_VIA_JOBS:-true}",
    "smtp_host": "${MAIL_SMTP_HOST}",
    "smtp_port": "${MAIL_SMTP_PORT:-587}",
    "smtp_username": "${MAIL_SMTP_USERNAME}",
    "smtp_password": "${MAIL_SMTP_PASSWORD}",
    "smtp_use_tls": true,
    "from": "${MAIL_FROM}",
    "from_name": "${MAIL_FROM_NAME}",
    "subject_prefix": "${MAIL_SUBJECT_PREFIX:-}",
    "timeout_sec": 30
  },
  "messaging": {
    "enabled": false
  },
  "api": {
    "public_paths": "/healthz,/ready,/health,/api/v1/auth/login,/api/v1/auth/register,/api/v1/auth/refresh,/api/v1/account/confirm/*,/api/v1/account/reset-password-request,/api/v1/account/reset-password/*,/api/v1/account/change-email/*,/api/v1/account/join-from-invite/*"
  },
  "docs": {
    "enabled": false
  },
  "security": {
    "hsts": true,
    "hsts_max_age": 31536000,
    "csrf": {
      "enabled": "${SECURITY_CSRF_ENABLED:-false}",
      "cookie_name": "csrf-token",
      "header_name": "X-CSRF-Token"
    }
  },
  "auth": {
    "mode": "jwt",
    "cookies": {
      "enabled": true,
      "access_name": "__Host-access",
      "refresh_name": "__Host-refresh",
      "access_ttl_sec": 900,
      "refresh_ttl_sec": 604800,
      "secure": true,
      "samesite": "Lax",
      "refresh_revocation_prefix": "auth:refresh:"
    },
    "jwt": {
      "secret": "${JWT_SECRET}",
      "issuer": "${JWT_ISSUER}",
      "audience": "${JWT_AUDIENCE}",
      "leeway_sec": 30,
      "roles_claim": "roles",
      "scopes_claim": "scope"
    }
  },
  "idempotency": {
    "enabled": true,
    "ttl_sec": 86400,
    "lock_ttl_sec": 30,
    "max_body_kb": 1024,
    "max_response_kb": 256
  },
  "rate_limit": {
    "enabled": true,
    "requests": "${RATE_LIMIT_REQUESTS:-120}",
    "window_sec": 60,
    "protected_requests": "${RATE_LIMIT_PROTECTED_REQUESTS:-10}",
    "protected_window_sec": 60,
    "scope": "ip_or_user",
    "trust_proxy": true,
    "fail_open": false,
    "whitelist": ""
  },
  "jobs": {
    "enabled": "${JOBS_ENABLED:-true}",
    "result_ttl": 86400,
    "max_retries": 3,
    "retry_backoff_base_ms": 1000,
    "retry_backoff_max_ms": 60000,
    "visibility_timeout_sec": 300
  },
  "worker": {
    "id": "${WORKER_ID:-worker-1}",
    "types": ["default"],
    "concurrency": "${WORKER_CONCURRENCY:-2}",
    "health_port": 9091,
    "brpop_timeout": 5
  }
}
